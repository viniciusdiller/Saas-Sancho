//.ENV


# Configuração do Servidor
PORT=

# Configuração da Base de Dados
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=

# Segredo para JWT de usuários comuns
JWT_SECRET=
PROVISION_WEBHOOK_SECRET=
# Ambiente
NODE_ENV=

# Channex
