CHANNEX_RETRY_ATTEMPTS=3
CHANNEX_BACKOFF_BASE_MS=1000
CHANNEX_RATE_LIMIT_PAUSE_MS=60000
CHANNEX_ARI_FLUSH_INTERVAL_MS=6000
